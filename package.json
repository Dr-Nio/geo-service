{
	"name": "@dr-nio/geo-service",
	"version": "2.2.0",
	"description": "Fully dynamic currency geolocation service with zero hard-coded values",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"browser": "dist/index.browser.js",
	"types": "src/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"browser": "./dist/index.browser.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"src",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "node build.js",
		"prepublishOnly": "npm run build",
		"test": "echo \"No tests specified\" && exit 0"
	},
	"keywords": [
		"geolocation",
		"ip",
		"address",
		"country",
		"currency",
		"locale",
		"dynamic",
		"browser",
		"intl",
		"zero-hardcode",
		"rate",
		"money",
		"seo",
		"dollar",
		"pounds",
		"euro"
	],
	"author": "Nicholas Oscar Okechukwu",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Dr-Nio/geo-service"
	},
	"bugs": {
		"url": "https://github.com/Dr-Nio/geo-service/issues"
	},
	"homepage": "https://github.com/Dr-Nio/geo-service#readme",
	"engines": {
		"node": ">=14.0.0"
	},
	"devDependencies": {
		"esbuild": "^0.28.1"
	}
}
